root = True

[*]
# Устанавливаем кодировку
charset = utf-8
indent_style = space
indent_size = 4

# --- Настройка StyleCop ---

[*.cs]
# --- Глушим косметику (SA) ---
dotnet_diagnostic.SA1208.severity = none    # Порядок using (System в начале)
dotnet_diagnostic.SA1503.severity = none    # Требование фигурных скобок в if
dotnet_diagnostic.SA1505.severity = none    # Пробел после открывающей скобки
dotnet_diagnostic.SA1507.severity = none    # Несколько пустых строк подряд
dotnet_diagnostic.SA1508.severity = none    # Пустая строка перед закрывающей скобкой
dotnet_diagnostic.SA1633.severity = none
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1413.severity = none
dotnet_diagnostic.SA1309.severity = none
dotnet_diagnostic.SA1200.severity = none 
dotnet_diagnostic.SA1101.severity = none 
dotnet_diagnostic.SA1512.severity = none    # Комментарии и пустые строки
dotnet_diagnostic.SA1515.severity = none    # Пустая строка перед комментарием
dotnet_diagnostic.SA1516.severity = none    # Пустая строка между элементами
dotnet_diagnostic.SA1602.severity = none    # XML-комментарии для Enum
dotnet_diagnostic.SA1116.severity = none    # Форматирование параметров на новых строках
dotnet_diagnostic.SA1000.severity = none    # Пробелы вокруг ключевых слов (new(), await() и т.д.)
dotnet_diagnostic.SA0001.severity = none    # Жалоба на отсутствие генерации XML-документации
dotnet_diagnostic.S6966.severity = none
dotnet_diagnostic.S6965.severity = none

# --- Глушим занудство Sonar (S) ---
dotnet_diagnostic.S1075.severity = none     # Хардкод URI/путей (в лабе это ок)
dotnet_diagnostic.S1186.severity = none     # Пустые методы (нужны для миграций)

# --- А вот важные вещи сделаем ОШИБКАМИ ---

# --- Настройка критических правил (делаем их ошибками) ---

# S1121: Запрещаем присваивание в условиях (if (x = y)) - очень частая баг-ошибка
dotnet_diagnostic.S1121.severity = error

# S1135: Запрещаем оставлять TODO в коде (чтобы не забывать недоделки)
dotnet_diagnostic.S1135.severity = error

# S2190: Запрещаем явную бесконечную рекурсию
dotnet_diagnostic.S2190.severity = error

# SA1028: Запрещаем лишние пробелы в конце строк (поддержание чистоты)
dotnet_diagnostic.SA1028.severity = error