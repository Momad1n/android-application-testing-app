@page "/dashboard"

<h3>Dashboard</h3>
<p>Here you can see API endpoints and testing controls.</p>

<div class="stats">
    <div class="stat-card">Pending Runs: 3</div>
    <div class="stat-card">Running: 2</div>
    <div class="stat-card">Passed: 5</div>
