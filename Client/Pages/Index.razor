@page "/"
@using System.Net.Http.Json
@using Client.Models
@inject HttpClient Http

<h3>Dashboard</h3>
<p>Here you can see real-time statistics from the backend.</p>

@if (testRuns == null || emulators == null)
{
    <p><em>Loading data...</em></p>
}
else
{
    <div class="stats">
        <div class="stat-card">Pending Runs: @testRuns.Count(x => x.Status == TestRunStatus.Pending)</div>
        <div class="stat-card">Running: @testRuns.Count(x => x.Status == TestRunStatus.Running)</div>
        <div class="stat-card bg-success text-white">Passed: @testRuns.Count(x => x.Status == TestRunStatus.Passed)</div>
        <div class="stat-card bg-danger text-white">Failed: @testRuns.Count(x => x.Status == TestRunStatus.Failed)</div>
        <div class="stat-card">Active Emulators: @emulators.Count(x => x.IsActive)</div>
    </div>
}

@code {
    private List<TestRun>? testRuns;
    private List<EmulatorConfiguration>? emulators;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            testRuns = await Http.GetFromJsonAsync<List<TestRun>>("api/TestRuns");
            emulators = await Http.GetFromJsonAsync<List<EmulatorConfiguration>>("api/EmulatorConfigurations");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching data: {ex.Message}");
        }
    }
}

<style>
    .stats { display: flex; gap: 16px; flex-wrap: wrap; }
    .stat-card {
        padding: 16px; background-color: #ecf0f1; border-radius: 6px;
        min-width: 140px; text-align: center; font-weight: bold;
    }
</style>